local function ZoneFishLogic()
    if not Options.ZoneFish.Value then
        if ZoneFishOrigin then
            TeleportTo(ZoneFishOrigin)
            ZoneFishOrigin = nil
            if Humanoid then for _, s in pairs(Enum.HumanoidStateType:GetEnumItems()) do Humanoid:SetStateEnabled(s, true) end end
        end
        return
    end
    local zones = workspace:FindFirstChild("zones") and workspace.zones:FindFirstChild("fishing")
    if not zones then return end
    local target = nil
    for _, zone in pairs(zones:GetChildren()) do if zone.Name == Options.ZoneFishDropdown.Value then target = zone break end end
    if not target then return end
    if not ZoneFishOrigin then
        ZoneFishOrigin = HumanoidRootPart.Position
        if Humanoid then for _, s in pairs(Enum.HumanoidStateType:GetEnumItems()) do if s ~= Enum.HumanoidStateType.Running then Humanoid:SetStateEnabled(s, false) end end end
    end
    TeleportTo(target.Position - Vector3.new(0, 20, 0))
    if Options.AutoZoneCast.Value then
        local tool = GetTool()
        if tool and tool:FindFirstChild("bobber") then
            local bobber = tool.bobber
            local rope = bobber:FindFirstChildOfClass("RopeConstraint")
            if rope then rope.Length = 9e9 end
            bobber:PivotTo(target:GetPivot())
        end
    end
end

