local function RandomDelay(minSec, maxSec) task.wait(minSec + math.random() * (maxSec - minSec)) end

local function GetTool()
    if Character and Character:FindFirstChildOfClass("Tool") then return Character:FindFirstChildOfClass("Tool") end
    local tool = LocalPlayer.Backpack:FindFirstChildOfClass("Tool")
    if tool then tool.Parent = Character end
    return tool
end

local function TeleportTo(pos)
    pcall(function() Character:PivotTo(CFrame.new(pos)) end)
end

local function SafeTeleport(pos)
    local ray = workspace:Raycast(pos, Vector3.new(0, -10, 0), RaycastParams.new())
    TeleportTo(ray and ray.Position + Vector3.new(0, 3, 0) or pos)
end

local function AutoCastLogic()
    local tool = GetTool()
    if not tool then return end
    local values, events = tool:FindFirstChild("values"), tool:FindFirstChild("events")
    if not values or not events then return end
    if values.casted and values.casted.Value == false and tick() - LastCastTime > Options.CastDelayMin.Value then
        LastCastTime = tick()
        local percent = Options.PerfectCast.Value and 100 or (Options.RandomCast.Value and math.random(90, 99) or 95)
        if events:FindFirstChild("cast") then events.cast:FireServer(percent, 1)
        elseif events:FindFirstChild("castAsync") then events.castAsync:InvokeServer(percent, 1) end
        if Options.InstantBob.Value then
            task.spawn(function()
                for _ = 1, 10 do
                    local bobber = tool:FindFirstChild("bobber")
                    if bobber then
                        local ray = workspace:Raycast(bobber.Position, Vector3.new(0, -100, 0))
                        if ray then bobber.CFrame = CFrame.new(ray.Position) break end
                    end
                    task.wait(0.05)
                end
            end)
        end
        RandomDelay(Options.CastDelayMin.Value, Options.CastDelayMax.Value)
    end
end

local function AutoReelLogic()
    local reelGui = LocalPlayer.PlayerGui:FindFirstChild("reel")
    if not reelGui then return end
    if Options.InstantReel.Value then
        local bar = reelGui:FindFirstChild("bar")
        if bar and bar:FindFirstChild("reel") and bar.reel.Enabled then
            task.wait(Options.ReelDelay.Value)
            ReplicatedStorage.events:FindFirstChild("reelfinished "):FireServer(100, Options.PerfectReel.Value)
        end
    elseif Options.AutoReel.Value then
        local bar = reelGui:FindFirstChild("bar")
        if bar then
            local playerBar, fishBar = bar:FindFirstChild("playerbar"), bar:FindFirstChild("fish")
            if playerBar and fishBar then
                local conn = RunService.RenderStepped:Connect(function()
                    if not reelGui.Parent then conn:Disconnect() end
                    local targetX = math.clamp(fishBar.Position.X.Scale, 0.15, 0.85)
                    playerBar.Position = UDim2.new(targetX, 0, playerBar.Position.Y.Scale, 0)
                end)
                task.delay(0.5, function() conn:Disconnect() end)
            end
        end
    end
end

