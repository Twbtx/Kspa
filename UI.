                valueLabel.TextColor3 = Color3.fromRGB(0, 170, 255)
                valueLabel.TextScaled = true
                valueLabel.Font = Enum.Font.Gotham
                
                local sliderBg = Instance.new("Frame")
                sliderBg.Parent = frame
                sliderBg.Size = UDim2.new(0.9, 0, 0, 4)
                sliderBg.Position = UDim2.new(0.05, 0, 0.7, 0)
                sliderBg.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
                sliderBg.BorderSizePixel = 0
                local corner = Instance.new("UICorner")
                corner.Parent = sliderBg
                corner.CornerRadius = UDim.new(1, 0)
                
                local fill = Instance.new("Frame")
                fill.Parent = sliderBg
                fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
                fill.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
                fill.BorderSizePixel = 0
                
                local sliderBtn = Instance.new("TextButton")
                sliderBtn.Parent = sliderBg
                sliderBtn.Size = UDim2.new(0, 12, 0, 12)
                sliderBtn.Position = UDim2.new((default - min) / (max - min), -6, 0.5, -6)
                sliderBtn.BackgroundColor3 = Color3.new(1, 1, 1)
                sliderBtn.Text = ""
                local btnCorner = Instance.new("UICorner")
                btnCorner.Parent = sliderBtn
                btnCorner.CornerRadius = UDim.new(1, 0)
                
                local dragging = false
                sliderBtn.MouseButton1Down:Connect(function()
                    dragging = true
                end)
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = false
                    end
                end)
                UserInputService.InputChanged:Connect(function(input)
                    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                        local pos = UserInputService:GetMouseLocation().X
                        local absPos = sliderBg.AbsolutePosition.X
                        local width = sliderBg.AbsoluteSize.X
                        local percent = math.clamp((pos - absPos) / width, 0, 1)
                        local val = min + percent * (max - min)
                        val = math.round(val)
                        fill.Size = UDim2.new(percent, 0, 1, 0)
                        sliderBtn.Position = UDim2.new(percent, -6, 0.5, -6)
                        valueLabel.Text = tostring(val)
                        if callback then callback(val) end
                    end
                end)
                
                frame.Parent = scroll
                return frame
            end,
            AddLabel = function(self, text)
                local label = Instance.new("TextLabel")
                label.Size = UDim2.new(0.96, 0, 0, 30)
                label.Position = UDim2.new(0.02, 0, 0, 0)
                label.BackgroundTransparency = 1
                label.Text = text
                label.TextColor3 = Color3.fromRGB(200, 200, 200)
                label.TextScaled = true
                label.TextXAlignment = Enum.TextXAlignment.Left
                label.Font = Enum.Font.Gotham
                label.Parent = scroll
                return label
            end
        }
        setmetatable(pageObj, {__index = pageObj})
        self.Pages[name] = pageObj
        if self.SideOrder == 1 then
            self:SwitchPage(name)
        end
        return pageObj
    end
    
    MakeDraggable(window)
    
    -- 最小化/关闭逻辑
    local minimized = false
    minimizeBtn.MouseButton1Click:Connect(function()
        if minimized then
            window:TweenSize(UDim2.new(widthScale, 0, heightScale, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.3, true)
            minimized = false
        else
            window:TweenSize(UDim2.new(0.05, 0, 0.05, 0), Enum.EasingDirection.In, Enum.EasingStyle.Quad, 0.3, true)
            minimized = true
        end
    end)
    
    closeBtn.MouseButton1Click:Connect(function()
        screenGui:Destroy()
    end)
    
    return winObj
end

return Kit