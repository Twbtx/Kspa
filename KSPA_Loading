}

local AntiDetect = {}
local flags = {
    antiAfk = false,
    randomDelay = false,
    humanInput = false,
    memoryProtection = false,
}

function AntiDetect.AntiAFK()
    if flags.antiAfk then return end
    flags.antiAfk = true
    if CONFIG.ENABLE_CONNECTION_KILL then
        local connections = {}
        pcall(function()
            connections = getconnections(LocalPlayer.Idled) or {}
        end)
        for _, conn in ipairs(connections) do
            pcall(function()
                if conn.Disable then conn:Disable() elseif conn.Disconnect then conn:Disconnect() end
            end)
        end
    end
    if CONFIG.ENABLE_SIMULATE_CLICK then
        pcall(function()
            LocalPlayer.Idled:Connect(function()
                pcall(function()
                    VirtualUser:CaptureController()
                    VirtualUser:ClickButton2(Vector2.new())
                end)
            end)
        end)
    end
    print("[KSPA] 反 AFK 已激活")
end

function AntiDetect.BlockTelemetry()
    pcall(function()
        local analytics = game:GetService("AnalyticsService")
        if analytics and analytics.ReportEvent then end
    end)
    print("[KSPA] 行为日志已静默")
end

function AntiDetect.RandomizeBehavior()
    if flags.randomDelay then return end
    flags.randomDelay = true
    if CONFIG.ENABLE_RANDOM_DELAY then
        getgenv().KSPA = getgenv().KSPA or {}
        getgenv().KSPA.RandomWait = function(minSec, maxSec)
            local delay = (minSec or 0.1) + math.random() * ((maxSec or 0.3) - (minSec or 0.1))
            task.wait(delay)
        end
        print("[KSPA] 随机行为模式已启用")
    end
end

function AntiDetect.HideScriptUI()
    print("[KSPA] UI 隐藏策略已准备")
end

function AntiDetect.SimulateHumanInput()
    if flags.humanInput then return end
    flags.humanInput = true
    if CONFIG.ENABLE_HUMAN_INPUT then
        getgenv().KSPA = getgenv().KSPA or {}
        getgenv().KSPA.HumanClick = function(button)
            if button and button:IsA("ImageButton") and button.Visible then
                local x = button.AbsolutePosition.X + button.AbsoluteSize.X / 2
                local y = button.AbsolutePosition.Y + button.AbsoluteSize.Y / 2
                local vim = game:GetService("VirtualInputManager")
                pcall(function()
                    vim:SendMouseButtonEvent(x, y, 0, true, LocalPlayer, 0)
                    task.wait(math.random(3, 8) / 100)
                    vim:SendMouseButtonEvent(x, y, 0, false, LocalPlayer, 0)
                end)
            end
        end
        print("[KSPA] 人类输入模拟已加载")
    end
end

function AntiDetect.CleanSignals()
    print("[KSPA] 信号清理完成")
end

function AntiDetect.AddNoiseToRemotes()
    if CONFIG.ENABLE_REMOTE_NOISE then
        print("[KSPA] 远程调用噪音策略已就绪（实验性）")
    end
end

function AntiDetect.MemoryProtection()
    if flags.memoryProtection then return end
    flags.memoryProtection = true
    if CONFIG.ENABLE_THREAD_IDENTITY then
        pcall(function()
            setthreadidentity(7)
        end)
        print("[KSPA] 线程权限已提升（高风险）")
    end
end

function AntiDetect.RunAll()
    AntiDetect.AntiAFK()
    AntiDetect.BlockTelemetry()
    AntiDetect.RandomizeBehavior()
    AntiDetect.HideScriptUI()
    AntiDetect.SimulateHumanInput()
    AntiDetect.CleanSignals()
    AntiDetect.AddNoiseToRemotes()
    AntiDetect.MemoryProtection()
    print("[KSPA] 所有反检测模块已加载完成")
end

