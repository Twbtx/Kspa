task.spawn(function()
    TweenService:Create(underline, TweenInfo.new(0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(0.5, 0, 0, 3)}):Play()
    for _, step in ipairs(steps) do
        statusLabel.Text = step.text
        TweenService:Create(loadingBar, TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(step.progress, 0, 1, 0)}):Play()
        if step.func then step.func() end
        task.wait(step.delay)
    end
    TweenService:Create(background, TweenInfo.new(1, Enum.EasingStyle.Quad), {BackgroundTransparency = 1}):Play()
    TweenService:Create(blur, TweenInfo.new(1, Enum.EasingStyle.Quad), {Size = 0}):Play()
    for _, child in ipairs(screenGui:GetDescendants()) do
        if child:IsA("Frame") and child ~= background then
            TweenService:Create(child, TweenInfo.new(1, Enum.EasingStyle.Quad), {BackgroundTransparency = 1}):Play()
        elseif child:IsA("TextLabel") or child:IsA("TextButton") then
            TweenService:Create(child, TweenInfo.new(1, Enum.EasingStyle.Quad), {TextTransparency = 1, BackgroundTransparency = 1}):Play()
        end
    end
    task.wait(1)
    screenGui:Destroy()
    blur:Destroy()
    print("[KSPA] 反检测已全面激活，准备加载主脚本...")
    if CONFIG.MAIN_SCRIPT_URL and CONFIG.MAIN_SCRIPT_URL ~= "" then
        local success, result = pcall(function()
            return game:HttpGet(CONFIG.MAIN_SCRIPT_URL)
        end)
        if success then
            local loadSuccess, loadErr = pcall(function()
                loadstring(result)()
            end)
            if not loadSuccess then
                warn("[KSPA] 主脚本执行失败: " .. tostring(loadErr))
            end
        else
            warn("[KSPA] 主脚本下载失败: " .. tostring(result))
        end
    else
        warn("[KSPA] 未配置 MAIN_SCRIPT_URL，请在脚本开头的 GAME_SCRIPTS 中添加当前游戏ID")
    end
end)

